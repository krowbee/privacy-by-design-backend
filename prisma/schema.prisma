// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User{
  id String @id @default(uuid())
  email String @unique
  password String
  role ActorType @default(USER)
  profile Profile?
}

model Profile{
  id String @id @default(uuid())
  firstName String
  lastName String
  address String
  passportNumber String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

enum EventActions {
  CREATE
  UPDATE
  READ
  DELETE

  LOGIN
  REGISTER
  LOGOUT
}

enum EventStatus {
  SUCCESS
  FAILURE
}

enum ActorType {
  ADMIN
  USER
  SYSTEM
}

enum EventCategories {
  SECURITY
  CRUD
  ERROR
}

model AuditEvent{
  category EventCategories
  id String @id @default(uuid())
  actorId String?
  actorType ActorType?
  ip String?
  metadata Json?
  action EventActions?
  entity String?
  entitySelector Json?
  status EventStatus
  created_at DateTime @default(now())
}

enum DocumentTypes {
  TERMS
  PRIVACY
}


model ConsentDocument {
  id String @id @default(uuid())
  type DocumentTypes
  version Float
  content String
  isActive Boolean
  userConsents UserConsent[]
}

model UserConsent{
  id String @id @default(uuid())
  consent ConsentDocument @relation(fields: [consentId], references: [id], onDelete: Cascade)
  consentId String
  revoked_at DateTime
  created_at DateTime @default(now())
}